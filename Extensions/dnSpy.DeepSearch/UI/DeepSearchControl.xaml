<UserControl x:Class="dnSpy.DeepSearch.UI.DeepSearchControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mvvm="clr-namespace:dnSpy.Contracts.MVVM;assembly=dnSpy.Contracts.DnSpy">

    <UserControl.Resources>
        <!-- Base style for leaf result rows -->
        <Style x:Key="DeepSearchTreeItemStyle" TargetType="TreeViewItem">
            <Setter Property="Background"                 Value="Transparent"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource TreeViewItemSelectedBackground}"/>
                    <Setter Property="Foreground" Value="{DynamicResource TreeViewItemSelectedForeground}"/>
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsMouseOver" Value="True"/>
                        <Condition Property="IsSelected"  Value="False"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="{DynamicResource TreeViewItemMouseOverTextBackground}"/>
                    <Setter Property="Foreground" Value="{DynamicResource TreeViewItemMouseOverForeground}"/>
                </MultiTrigger>
            </Style.Triggers>
        </Style>

        <!-- Group style: adds IsExpanded two-way binding -->
        <Style x:Key="DeepSearchGroupItemStyle" TargetType="TreeViewItem"
               BasedOn="{StaticResource DeepSearchTreeItemStyle}">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
        </Style>

        <!-- Leaf item template (DeepSearchResultVM) -->
        <DataTemplate x:Key="ResultItemTemplate">
            <Grid Margin="2,1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="#2B579A" CornerRadius="2"
                        Padding="3,0" Margin="0,0,5,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding KindLabel}" Foreground="White"
                               FontFamily="Consolas" FontSize="10" FontWeight="Bold"/>
                </Border>
                <TextBlock Grid.Column="1" Text="{Binding DisplayName}"
                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="{Binding Location}"
                           Opacity="0.65" FontSize="10" Margin="6,0,0,0"
                           MaxWidth="220"
                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Background="{DynamicResource TreeViewBackground}">
        <Grid.RowDefinitions>
            <!-- Row 0: Search bar -->
            <RowDefinition Height="Auto"/>
            <!-- Row 1: Type filter -->
            <RowDefinition Height="Auto"/>
            <!-- Row 2: Match mode + case sensitivity -->
            <RowDefinition Height="Auto"/>
            <!-- Row 3: Scope checkboxes -->
            <RowDefinition Height="Auto"/>
            <!-- Row 4: Opcode filter (conditional) -->
            <RowDefinition Height="Auto"/>
            <!-- Row 5: Source radio buttons -->
            <RowDefinition Height="Auto"/>
            <!-- Row 6: Folder row (conditional) -->
            <RowDefinition Height="Auto"/>
            <!-- Row 7: Namespace filter + toolbar -->
            <RowDefinition Height="Auto"/>
            <!-- Row 8: Results tree -->
            <RowDefinition Height="*"/>
            <!-- Row 9: Status bar -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Row 0: Search term + action buttons ─────────────────────────── -->
        <DockPanel Grid.Row="0" Margin="4,4,4,2" LastChildFill="True">
            <Button DockPanel.Dock="Right" Content="Cancel" Margin="4,0,0,0" MinWidth="60"
                    Command="{Binding CancelCommand}"/>
            <Button DockPanel.Dock="Right" Content="Search" Margin="4,0,0,0" MinWidth="60"
                    Command="{Binding SearchCommand}"/>
            <ComboBox HorizontalAlignment="Stretch"
                      IsEditable="True"
                      Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}"
                      ItemsSource="{Binding SearchHistory}"
                      x:Name="SearchBox">
                <ComboBox.InputBindings>
                    <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                </ComboBox.InputBindings>
            </ComboBox>
        </DockPanel>

        <!-- ── Row 1: Type filter ───────────────────────────────────────────── -->
        <DockPanel Grid.Row="1" Margin="6,1,4,2">
            <TextBlock DockPanel.Dock="Left" Text="Type filter:" VerticalAlignment="Center" Margin="0,0,6,0" Opacity="0.8"/>
            <TextBox Text="{Binding TypeFilter, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Narrows Methods results to those whose return type or a parameter type contains this text"
                     VerticalAlignment="Center"/>
        </DockPanel>

        <!-- ── Row 2: Match mode + case sensitivity ───────────────────────── -->
        <WrapPanel Grid.Row="2" Orientation="Horizontal" Margin="6,2,4,2">
            <TextBlock Text="Match:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <RadioButton Content="Substring" IsChecked="{Binding IsSubstring}" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <RadioButton Content="Wildcard"  IsChecked="{Binding IsWildcard}"  VerticalAlignment="Center" Margin="0,0,8,0"/>
            <RadioButton Content="Regex"     IsChecked="{Binding IsRegex}"     VerticalAlignment="Center" Margin="0,0,12,0"/>
            <CheckBox    Content="Case-sensitive" IsChecked="{Binding CaseSensitive}" VerticalAlignment="Center"/>
        </WrapPanel>

        <!-- ── Row 3: Scope checkboxes ───────────────────────────────────────── -->
        <WrapPanel Grid.Row="3" Orientation="Horizontal" Margin="6,2,4,2">
            <TextBlock Text="Scope:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <CheckBox Content="Types"       IsChecked="{Binding ScopeTypes}"       VerticalAlignment="Center" Margin="0,0,8,0"/>
            <CheckBox Content="Methods"     IsChecked="{Binding ScopeMethods}"     VerticalAlignment="Center" Margin="0,0,8,0"/>
            <CheckBox Content="Fields"      IsChecked="{Binding ScopeFields}"      VerticalAlignment="Center" Margin="0,0,8,0"/>
            <CheckBox Content="Strings"     IsChecked="{Binding ScopeStrings}"     VerticalAlignment="Center" Margin="0,0,8,0"/>
            <CheckBox Content="Attributes"  IsChecked="{Binding ScopeAttributes}"  VerticalAlignment="Center" Margin="0,0,8,0"
                      ToolTip="Search custom attributes ([Obsolete], [DllImport], etc.)"/>
            <CheckBox Content="Inheritance" IsChecked="{Binding ScopeInheritance}" VerticalAlignment="Center" Margin="0,0,8,0"
                      ToolTip="Find types by base class or implemented interface name"/>
            <CheckBox Content="IL Opcodes"  IsChecked="{Binding ScopeILOpcodes}"   VerticalAlignment="Center"
                      ToolTip="Find method bodies containing a specific IL opcode"/>
        </WrapPanel>

        <!-- ── Row 4: Opcode filter (visible only when IL Opcodes scope is on) ── -->
        <DockPanel Grid.Row="4" Margin="6,1,4,2"
                   Visibility="{Binding IsOpcodeFilterVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock DockPanel.Dock="Left" Text="Opcode:" VerticalAlignment="Center" Margin="0,0,6,0" Opacity="0.8"/>
            <TextBox Text="{Binding OpcodeFilter, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="IL opcode name to match, e.g. ldsfld, call, newobj, throw"
                     VerticalAlignment="Center"/>
        </DockPanel>

        <!-- ── Row 5: Source radio buttons ──────────────────────────────────── -->
        <WrapPanel Grid.Row="5" Orientation="Horizontal" Margin="6,2,4,2">
            <TextBlock Text="Source:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <RadioButton Content="Loaded assemblies" IsChecked="{Binding SourceLoaded}"   VerticalAlignment="Center" Margin="0,0,8,0"/>
            <RadioButton Content="Folder"            IsChecked="{Binding SourceFolder}"   VerticalAlignment="Center" Margin="0,0,8,0"/>
            <RadioButton Content="Both"              IsChecked="{Binding SourceBoth}"     VerticalAlignment="Center" Margin="0,0,8,0"/>
            <RadioButton Content="Attached process"  IsChecked="{Binding SourceAttached}" VerticalAlignment="Center"/>
        </WrapPanel>

        <!-- ── Row 6: Folder path (hidden when source = loaded or attached) ─── -->
        <Grid Grid.Row="6" Margin="6,2,4,2"
              Visibility="{Binding IsFolderVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox  Grid.Column="0" Text="{Binding FolderPath, UpdateSourceTrigger=PropertyChanged}"
                      VerticalAlignment="Center"/>
            <Button   Grid.Column="1" Content="Browse…" Margin="4,0,8,0"
                      Command="{Binding BrowseFolderCommand}"/>
            <CheckBox Grid.Column="2" Content="Subfolders" IsChecked="{Binding SearchSubfolders}" VerticalAlignment="Center"/>
        </Grid>

        <!-- ── Row 7: Namespace filter + action toolbar ──────────────────────── -->
        <DockPanel Grid.Row="7" Margin="4,2,4,2">
            <!-- Toolbar buttons on the right -->
            <Button DockPanel.Dock="Right" Content="Diff" Margin="4,0,0,0" MinWidth="42"
                    Command="{Binding ToggleDiffCommand}"
                    ToolTip="Toggle diff mode — shows only results added since the last snapshot"/>
            <Button DockPanel.Dock="Right" Content="Snapshot" Margin="4,0,0,0" MinWidth="62"
                    Command="{Binding SnapshotCommand}"
                    ToolTip="Save the current results as a baseline for diff comparison"/>
            <Button DockPanel.Dock="Right" Content="Export…" Margin="4,0,0,0" MinWidth="62"
                    Command="{Binding ExportCommand}"
                    ToolTip="Export results to CSV or plain text"/>
            <!-- Namespace filter TextBox fills remaining width -->
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Left" Text="NS filter:" VerticalAlignment="Center" Margin="0,0,4,0" Opacity="0.8"/>
                <TextBox Text="{Binding NamespaceFilter, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Filter displayed results by namespace (no re-search needed)"
                         VerticalAlignment="Center"/>
            </DockPanel>
        </DockPanel>

        <!-- ── Row 8: Results tree ─────────────────────────────────────────── -->
        <TreeView Grid.Row="8" Margin="4,4,4,2"
                  x:Name="ResultsTree"
                  Background="{DynamicResource TreeViewBackground}"
                  BorderBrush="{DynamicResource TreeViewBorder}"
                  BorderThickness="1"
                  mvvm:InitDataTemplateAP.Initialize="True"
                  ItemsSource="{Binding FilteredResultGroups}"
                  ItemContainerStyle="{StaticResource DeepSearchGroupItemStyle}"
                  MouseDoubleClick="OnResultMouseDoubleClick"
                  KeyDown="OnResultKeyDown"
                  PreviewMouseRightButtonDown="OnResultPreviewMouseRightButtonDown">

            <TreeView.ContextMenu>
                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                    <MenuItem Header="Copy Name"          Command="{Binding CopyNameCommand}"
                              ToolTip="Copy fully-qualified member name to clipboard"/>
                    <MenuItem Header="Copy Assembly Path" Command="{Binding CopyPathCommand}"
                              ToolTip="Copy the assembly file path to clipboard"/>
                    <MenuItem Header="Copy All Results"   Command="{Binding CopyAllResultsCommand}"
                              ToolTip="Copy all visible results as formatted text"/>
                    <Separator/>
                    <MenuItem Header="Find Callers"       Command="{Binding FindCallersCommand}"
                              ToolTip="Find all call/callvirt sites that call this method across loaded assemblies"/>
                </ContextMenu>
            </TreeView.ContextMenu>

            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate ItemsSource="{Binding Results}"
                                          ItemTemplate="{StaticResource ResultItemTemplate}"
                                          ItemContainerStyle="{StaticResource DeepSearchTreeItemStyle}">
                    <TextBlock Text="{Binding Header}" FontWeight="SemiBold" Margin="2,1"/>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>

        <!-- ── Row 9: Status bar ─────────────────────────────────────────────── -->
        <Border Grid.Row="9" BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource CommonControlsTextBoxBorderBrush}">
            <Grid Margin="4,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusText}"
                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                <!-- Result count badge -->
                <TextBlock Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center" FontSize="10" Opacity="0.75"
                           Text="{Binding ResultSummary}"/>
                <!-- Progress bar: determinate when total is known, indeterminate while collecting targets -->
                <ProgressBar Grid.Column="2" Width="80" Height="12" Margin="8,0,0,0"
                             IsIndeterminate="{Binding IsProgressIndeterminate}"
                             Value="{Binding ProgressValue, Mode=OneWay}"
                             Maximum="{Binding ProgressMax, Mode=OneWay, FallbackValue=1}"
                             Visibility="{Binding IsSearching, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
